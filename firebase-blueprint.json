{
  "entities": {
    "users": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": {
          "type": "object",
          "properties": {
            "aiTone": { "type": "string", "enum": ["professional", "creative", "concise"] },
            "defaultMode": { "type": "string", "enum": ["standard", "bespoke", "image"] }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "messages": {
      "title": "Message",
      "description": "A single chat message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "groundingMetadata": { "type": "array" },
        "generatedImage": { "type": "string" },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "data": { "type": "string" },
              "mimeType": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "required": ["role", "content", "timestamp"]
    },
    "conversations": {
      "title": "Conversation",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    },
    "/users/{userId}/conversations/{conversationId}": {
      "schema": "conversations",
      "description": "Chat sessions for a user"
    },
    "/users/{userId}/conversations/{conversationId}/messages/{messageId}": {
      "schema": "messages",
      "description": "Messages within a specific conversation"
    }
  }
}
